# FutOdds backend — copy to .env.local (npm run dev:local) or .env.testnet (npm run start:testnet)

# --- required ---

# Solana RPC the backend reads/writes through
# localnet: http://127.0.0.1:8899 · testnet: https://api.testnet.solana.com
SOLANA_RPC_URL=http://127.0.0.1:8899

# Keypair that signs oracle updates and settlements (~ is expanded)
ORACLE_KEYPAIR=~/.config/solana/id.json

# Deployed program IDs (see Anchor.toml)
# localnet: oracle HwDVX9fTTxmnLBJwtig7ugsWuiqLh14pj71WtxQaaSSa · betting 67mbZdR3KxZxRxgKDMT7JbxtYU92C1y81Q4KKGQRkMMY
# testnet:  oracle Df1gfgegKEBJvKtyHdxUiwaohUkDQj9Pigdpgszk7XUL · betting H3ekojbWVFfzYnTmiNUejMkiB2pEQuf6wyH7QyyMQkz1
ORACLE_PROGRAM_ID=HwDVX9fTTxmnLBJwtig7ugsWuiqLh14pj71WtxQaaSSa
BETTING_PROGRAM_ID=67mbZdR3KxZxRxgKDMT7JbxtYU92C1y81Q4KKGQRkMMY

# TxLINE odds feed credentials (scripts/txline-activate-devnet.js activates the token)
TXLINE_API_ORIGIN=https://sportsapi.txodds.com
TXLINE_GUEST_JWT=
TXLINE_API_TOKEN=

# --- optional (defaults shown) ---

# PORT=8787
# TEST_USDC_MINT=CDAQWBQ3DciCWQDtyczAWvTp3xuyuL2t273LSdffjxB
# ODDS_POLL_INTERVAL_MS=60000
# SETTLEMENT_INTERVAL_MS=10000
# TXLINE_SUPER_ODDS_TYPE=1X2
# TXLINE_MARKET_PERIOD=FullTime
# TXLINE_COMPETITION_ID=
# TXLINE_START_EPOCH_DAY=

# --- scripts/txline-activate-devnet.js only (defaults shown) ---

# ANCHOR_PROVIDER_URL=https://api.devnet.solana.com
# ANCHOR_WALLET=~/.config/solana/id.json
# TXLINE_SERVICE_LEVEL_ID=1
# TXLINE_DURATION_WEEKS=4
# comma-separated league ids from SoccerSupportedLeagues.csv
# TXLINE_SELECTED_LEAGUES=
# reuse an existing subscription tx signature instead of subscribing again
# TXLINE_SUBSCRIBE_TX=

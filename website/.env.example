# oddsdex website — copy to .env.local
# NEXT_PUBLIC_ vars are inlined into the browser bundle at build time.

# FutOdds backend that serves GET /pools and GET /pools/positions/:owner
NEXT_PUBLIC_BACKEND_URL=http://localhost:8787

# Optional: override the RPC used by the browser for wallet transactions.
# Defaults to the rpcUrl reported by the backend's /pools response.
# NEXT_PUBLIC_SOLANA_RPC_URL=https://api.testnet.solana.com
